tb_long <- tb_dept %>%
  pivot_longer(
    cols = matches("^P[1-4]_dept$"),
    names_to = c("episode", ".value"),
    names_pattern = "P([1-4])_(.*)"
  ) %>%
  filter(nb_bite != 99) %>%
  filter(as.numeric(episode) <= nb_bite)

# Region of tick bites
tb_reg <- tb_long %>%
  mutate(region_residence = as.factor(region_residence)) %>%
  left_join(dep_reg, by = c("dept" = "CODE_DEPT")) %>%
  rename(region_bitten = CODE_REG) %>%
  select(- res_dept, - dept)


tb_reg_year <- tb_reg %>%
  filter(! is.na(region_bitten)) %>%
  mutate(region_bitten = droplevels(region_bitten)) %>%
  mutate(
    annual_period = case_when(
      survey_id == "winter_22" ~ "annual_22",
      survey_id %in% c("spring_23", "summer_23", "winter_23") ~ "annual_23",   
      survey_id %in% c("spring_24", "summer_24", "winter_24") ~ "annual_24",
