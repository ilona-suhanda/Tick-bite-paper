pop_REG <- pop_merge %>%
  group_by(CODE_REG, AGE, SEX, YEAR) %>%
  summarise(POP = sum(POP))

pop_REG_2025 <- pop_REG %>%
  filter(YEAR == 2025)

# Grouped by age
pop_grouped_over20 <- pop_REG_2025 %>%
  mutate(age_group = case_when(
    AGE %in% c("< 5", "5-9", "10-14", "15-19") ~ "Under 20",
    AGE %in% c("20-24", "25-29", "30-34") ~ "20-34",
    AGE %in% c("35-39", "40-44", "45-49") ~ "35-49",
    AGE %in% c("50-54", "55-59", "60-64") ~ "50-64",
    AGE %in% c("65-69", "70-74", "75-79") ~ "65-79",
    AGE %in% c("80-84", "85-89", "90-94", ">= 95") ~ "80 and older",
    TRUE ~ NA
  ))

## population per region
pop_ref_20plus <- pop_grouped_over20 %>%
  filter(age_group != "Under 20") %>%
  group_by(CODE_REG) %>%
  summarise(POP = sum(POP))

pop_ref_20plus$POP_FR <- sum(pop_ref_20plus$POP)


######* Post stratification weight ######


# Proportion of certain age-sex group in French population
pop_FR_age_sex <- pop_grouped_over20 %>%
  filter(age_group != "Under 20") %>%
  droplevels() %>%
  group_by(SEX, age_group) %>%
  summarise(POP = sum(POP), .groups = "drop") %>%
  mutate(POP_total = sum(POP),
         prop_POP = POP / POP_total)


# Unique participants per age group and sex
unique_par_age_sex <- data_over20 %>%
  arrange(version_date) %>%
  group_by(participantID) %>%
  summarise(
    age_group = first(age_group),
    SEX = first(SEX),   
    .groups = "drop"
  )

# Proportion of certain age-sex group in survey data
participant_age_sex <- unique_par_age_sex %>%
  group_by(SEX, age_group) %>%
  summarise(n_par = n(), .groups = "drop") %>%
  mutate(n_total = sum(n_par),
         prop_par = n_par / n_total)


### post stratification weight
post_stra <- participant_age_sex %>%
  left_join(pop_FR_age_sex, by = c("SEX", "age_group")) %>%
  mutate(weight = prop_POP / prop_par)


# Assign the weight to each participantID
unique_par_age_sex_w <- unique_par_age_sex %>%
  left_join(
    post_stra %>% select(SEX, age_group, weight),
    by = c("SEX", "age_group")
  )

# Add the weight to the data 
data_over20_weight <- data_over20 %>%
  left_join(unique_par_age_sex_w %>%
              select(participantID, weight),
            by = "participantID")


######* Participants per year per region ######

# 1 epidemiological year = 3 surveys (March-June, July-October, November-February)

# spring = March-June
# summer = July-October
# winter = November-February

par_year_reg <- data_over20_weight %>%
  mutate(
    annual_period = case_when(
      survey_id == "winter_22" ~ "annual_22",
      survey_id %in% c("spring_23", "summer_23", "winter_23") ~ "annual_23",
      survey_id %in% c("spring_24", "summer_24", "winter_24") ~ "annual_24",
      TRUE ~ NA
    )
  ) %>%
  # collapse to unique participant per year & region
  group_by(participantID, CODE_REG, annual_period) %>%
  summarise(weight = first(weight), .groups = "drop") %>%   
  # sum by region
  group_by(CODE_REG, annual_period) %>%
  summarise(
    n_par = n(),              # number of participants
    n_par_w = sum(weight),    # number of weighted participants
    .groups = "drop"
  ) %>%
  filter(annual_period != "annual_22") 


######* Location of tick bites ######

# Extract the departments for all tick bite episodes
tb_dept <- data_over20_weight %>%
  filter(bitten_study_period == 1) %>%
