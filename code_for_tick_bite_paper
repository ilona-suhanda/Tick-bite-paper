######* INLA model ######

# Variables selection
formula <- list(Y,Y2) ~ -1 + Inte_B + Inte_P + 
  # Binomial
  age_B_45_74 + age_B_75_plus + sex_B_F + res_green_outdoor_B + region_B_24 + region_B_27 + region_B_28 + region_B_32 +
  region_B_44 + region_B_52 + region_B_53 + region_B_75 + region_B_76 + region_B_84 + region_B_93 + region_B_94 +
  temp_B_2 + temp_B_3 + temp_B_4 + rh_B_2 + rh_B_3 + rh_B_4 + clc_for_B + clc_agri_B + clc_arti_B +
  env_forest_B + env_meadow_B + env_garden_B + env_agri_B + env_park_B + env_mount_B +
  freq_act_B_2 + freq_act_B_3 + freq_act_B_4 + freq_act_B_5 + freq_prev_B_2 + freq_prev_B_3 +
  # Poisson
  clc_for_P + clc_agri_P + bitten_env_forest_P + bitten_env_meadow_P + bitten_env_garden_P + 
  bitten_env_agri_P + bitten_env_park_P + bitten_env_int_P + bitten_env_farm_P + bitten_env_water_P + 
  bit_act_prof_P + bit_act_hunt_fish_P + bit_act_sport_P + bit_act_leisure_P +
  freq_act_P_2 + freq_act_P_3 + freq_act_P_4 + freq_act_P_5 + freq_prev_P_2 + freq_prev_P_3 +
  consult_gp_P + remove_tick_P_2 + remove_tick_P_3 +
  # Random effects
  f(par_id, model="iid") +
  f(survey_id, model="seasonal", season.length=3)


res <- inla(formula,
            data=inla.stack.data(stack_BP),
            family=c("binomial","nzpoisson"),
            control.predictor=list(A=inla.stack.A(stack_BP), compute=TRUE),
            control.compute=list(dic=TRUE, waic=TRUE, cpo=TRUE))

