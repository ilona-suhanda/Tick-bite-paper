    )) %>%
  mutate(bitten_in_home_region = region_residence == region_bitten)
# check whether participants were bitten in their region of residence

# focus on epidemiological year 2023 and 2024
tb_reg_year_2324 <- tb_reg_year %>%
  filter(annual_period != "annual_22")

# bitten at least once in the region of residence in a year
participant_year <- tb_reg_year_2324 %>%
  group_by(participantID, annual_period, region_residence) %>%
  summarise(
    bitten_in_res_region = as.integer(any(bitten_in_home_region)),  
    weight = first(weight),
    .groups = "drop"
  )


######* Bitten participants per year per region ######

cases_region_year <- participant_year %>%
  group_by(region_residence, annual_period) %>%
  summarise(
    n_case = sum(bitten_in_res_region),                # number of bitten participants
    n_case_w = sum(weight * bitten_in_res_region),     # number of weighted bitten participants
    .groups = "drop"
  )


######* Merge data to calculate the incidence ######

merged_data_within_year <- par_year_reg %>%
  mutate(CODE_REG = as.factor(CODE_REG)) %>%
  left_join(
    cases_region_year,
    by = c("CODE_REG"="region_residence", "annual_period")
  ) %>%
  mutate(n_case = replace_na(n_case, 0),
         n_case_w = replace_na(n_case_w, 0))

inc_data <- merged_data_within_year %>%
  left_join(pop_ref_20plus, by="CODE_REG")



######* Yearly incidence per region ######

inc_year_reg <- inc_data %>%
  rowwise() %>%
  mutate(
    # with post stratification weight
    # proportion of bitten individual among participant
    rate_w = n_case_w / n_par_w,

    ci_w = list(binom.confint(n_case_w, n_par_w, method = "wilson")),
    ci_low_w = ci_w$lower,
    ci_up_w  = ci_w$upper,
    
    # estimate bitten individual in population
    bitten_pop_w = rate_w * POP,
    bitten_pop_low_w = ci_low_w * POP,
    bitten_pop_up_w = ci_up_w * POP,
    
    # incidence per 100,000 
    inc_ar_100_w = round(bitten_pop_w / POP * 100000, 2),
    ci_low_100_w = round(bitten_pop_low_w / POP * 100000, 2),
    ci_up_100_w = round(bitten_pop_up_w / POP * 100000, 2),
  )


######* National yearly incidence ######

inc_year_nat <- inc_year_reg %>%
  # adjust regional incidence according to the population size
  mutate(inc_ar_100_w_adj = inc_ar_100_w * POP / POP_FR,
         ci_low_100_w_adj = ci_low_100_w * POP / POP_FR,
         ci_up_100_w_adj = ci_up_100_w * POP / POP_FR) %>%
  group_by(annual_period) %>%
  summarise(inc_nat_100_w = sum(inc_ar_100_w_adj),
            ci_low_100_w = sum(ci_low_100_w_adj),
            ci_up_100_w = sum(ci_up_100_w_adj))  



