  mutate(age_group = case_when(age_cor >= 20 & age_cor <= 34 ~ "20-34",
                               age_cor >= 35 & age_cor <= 49 ~ "35-49",
                               age_cor >= 50 & age_cor <= 64 ~ "50-64",
